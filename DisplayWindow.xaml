<Window x:Class="DSDsp.DisplayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DSDsp"
        mc:Ignorable="d"
        Title="表示ウィンドウ(モニター用)" Height="450" Width="800"
        Background="Black">
    <Grid Background="Black">
        <Viewbox Stretch="Uniform"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center">
            <Grid x:Name="ContentGrid" Width="641" Height="387">
                <!-- 画面コンテンツがここに動的に配置されます -->
                <!-- 16:9の比率を維持しながら、ウィンドウサイズに応じて拡大・縮小されます -->
            </Grid>
        </Viewbox>
        <!-- 全画面ウィンドウ用ミラー表示レイヤー。SetMirrorSource() でソースをセットする。 -->
        <Rectangle x:Name="MirrorRect"
                   Visibility="Collapsed"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch">
            <Rectangle.Fill>
                <!-- Viewbox を ContentGrid の固定サイズ(641×387)に固定する。
                     TranslateTransform で範囲外に出た要素が bounding box を広げて
                     VisualBrush 全体が縮小・ズームアウトして見える現象を防ぐ。 -->
                <VisualBrush x:Name="MirrorBrush"
                             Stretch="Uniform"
                             AutoLayoutContent="False"
                             ViewboxUnits="Absolute"
                             Viewbox="0,0,641,387"/>
            </Rectangle.Fill>
        </Rectangle>
    </Grid>
</Window>

