            <Label x:Name="LB_種目カテゴリ" Content="Label" HorizontalContentAlignment="Center" Canvas.Left="130" Canvas.Top="67" Width="242" Height="40" Foreground="White" FontSize="18" FontFamily="Segoe UI Semibold" RenderTransformOrigin="0.492,2.971" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        </Canvas>
    </Grid>
</UserControl>
