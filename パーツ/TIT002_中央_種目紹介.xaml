                    <TranslateTransform x:Name="IM_種目2_Translate" X="0" Y="0"/>
                </Image.RenderTransform>
            </Image>
            <Image x:Name="IM_種目1" Height="126" Source="..\イメージ\CHR169_タイトル1.png" Stretch="Fill" Width="443" Canvas.Left="31" Canvas.Top="34" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Image.RenderTransform>
                    <TranslateTransform x:Name="IM_種目1_Translate" X="0" Y="0"/>
                </Image.RenderTransform>
            </Image>
            <Label x:Name="LB_種目紹介" Content="Label" HorizontalContentAlignment="Center" Canvas.Left="44" Canvas.Top="97" HorizontalAlignment="Center" VerticalAlignment="Top" Width="417" Height="40" Foreground="White" FontSize="24" FontFamily="Segoe UI Semibold" RenderTransformOrigin="0.492,2.971"/>
