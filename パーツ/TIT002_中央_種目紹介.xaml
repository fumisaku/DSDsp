<UserControl x:Class="DSDsp.パーツ.TIT002_中央_種目紹介"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DSDsp.パーツ"
             mc:Ignorable="d" 
              d:DesignHeight="387" d:DesignWidth="641">
    <Grid>
        <Canvas x:Name="COM_種目紹介" Margin="58,103,58,94" Background="Transparent">
            <Image x:Name="IM_種目2" Height="126" Source="..\イメージ\CHR169_タイトル2.png" Stretch="Fill" Width="443" Canvas.Left="24" Canvas.Top="26" HorizontalAlignment="Left" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
