<UserControl x:Class="DSDsp.フレーム.フレーム16対9_UC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:DSDsp.フレーム"
             mc:Ignorable="d"
             Height="387" Width="641">
    <Grid>
        <!-- Frame コントロールは Loaded 時にナビゲーション遷移フェードインを実行するため
             VisualBrush でミラー表示するとスクリーン側で背景がフェードインしてしまう。
             ナビゲーション機能が不要なため Frame を Border に置き換えて問題を解消する。 -->
        <Border x:Name="Frame_背景"  Width="641" Background="Green"/>
        <Border x:Name="Frame_左上"  Width="641"/>
        <Border x:Name="Frame_右上"  Width="641"/>
        <Border x:Name="Frame_右上2" Width="641"/>
        <Border x:Name="Frame_下中央" Width="641"/>

        <Border x:Name="Frame_1" Width="641"/>
        <Border x:Name="Frame_2" Width="641"/>
        <Border x:Name="Frame_3" Width="641"/>
        <Border x:Name="Frame_4" Width="641"/>
        <Border x:Name="Frame_5" Width="641"/>

        <Rectangle x:Name="Layer_1" Stroke="Black" Width="641">
            <Rectangle.Fill>
                <VisualBrush Stretch="Fill" Visual="{Binding}"/>
            </Rectangle.Fill>
        </Rectangle>
        <Rectangle x:Name="Layer_2" Stroke="Black" Width="641">
            <Rectangle.Fill>
                <VisualBrush Stretch="Fill" Visual="{Binding}"/>
            </Rectangle.Fill>
        </Rectangle>
        <Rectangle x:Name="Layer_3" Stroke="Black" Width="641">
            <Rectangle.Fill>
                <VisualBrush Stretch="Fill" Visual="{Binding}"/>
            </Rectangle.Fill>
        </Rectangle>

    </Grid>
</UserControl>

