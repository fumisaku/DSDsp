<local:DSDspScreenBase x:Class="DSDsp.画面.DSP_TIT_001_区分ラウンド紹介"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DSDsp.画面"
        xmlns:parts="clr-namespace:DSDsp.パーツ"
        xmlns:frame="clr-namespace:DSDsp.フレーム"
        mc:Ignorable="d"
        Height="387" Width="641">
        <Grid RenderTransformOrigin="0.161,0.542">
            <!-- フレーム16対9背景 -->
            <frame:フレーム16対9_UC x:Name="FrameBackground"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"/>

            <!-- 左上パーツ: JDSFロゴと競技会名 -->
            <parts:COM001_左上 x:Name="PartsCOM001"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"
                   Margin="0,0,0,0"/>

        <!-- タイトル -->
            <parts:TIT001_中央タイトル大 x:Name="PartsTIT001"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"
                   Margin="0,0,0,0"/>

    </Grid>
</local:DSDspScreenBase>

