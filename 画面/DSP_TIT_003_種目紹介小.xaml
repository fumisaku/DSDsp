<local:DSDspScreenBase x:Class="DSDsp.画面.DSP_TIT_003_種目紹介小"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DSDsp.画面"
             xmlns:parts="clr-namespace:DSDsp.パーツ"
             xmlns:frame="clr-namespace:DSDsp.フレーム"
             mc:Ignorable="d" 
             Height="387" Width="641">
    <Grid>
        <!-- フレーム16対9背景 -->
        <frame:フレーム16対9_UC x:Name="FrameBackground"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"/>

        <!-- 左上パーツ: JDSFロゴと競技会名 -->
        <parts:COM001_左上 x:Name="PartsCOM001"
               HorizontalAlignment="Left"
               VerticalAlignment="Top"
               Margin="0,0,0,0"/>

        <!-- 右上パーツ: 種目名 -->
        <parts:COM002_右上01 x:Name="PartsCOM002"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="0,0,0,0"/>

        <!-- タイトル -->
        <parts:TIT003_下_種目紹介 x:Name="PartsTIT003"
               HorizontalAlignment="Left"
               VerticalAlignment="Top"
               Margin="0,37,0,0"/>
    </Grid>
</local:DSDspScreenBase>

