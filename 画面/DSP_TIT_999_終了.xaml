<local:DSDspScreenBase x:Class="DSDsp.画面.DSP_TIT_999_終了"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DSDsp.画面"
        xmlns:parts="clr-namespace:DSDsp.パーツ"
        xmlns:frame="clr-namespace:DSDsp.フレーム"
        mc:Ignorable="d"
        Height="387" Width="641">
    <Grid>
        <!-- フレーム16対9背景 -->
        <frame:フレーム16対9_UC x:Name="FrameBackground"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"/>

        <!-- 左上パーツ: JDSFロゴと競技会名 -->
        <parts:COM001_左上 x:Name="PartsCOM001"
               HorizontalAlignment="Left"
               VerticalAlignment="Top"
               Margin="0,0,0,0"/>

        <!-- 終了テキスト（中央表示） -->
        <Label x:Name="LB_終了"
               Content="終　了"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               FontSize="48"
               FontWeight="Bold"
               FontFamily="Segoe UI Semibold"
               Foreground="White"
               Opacity="0">
            <Label.RenderTransform>
                <TranslateTransform x:Name="LB_終了_Translate" X="0" Y="0"/>
            </Label.RenderTransform>
        </Label>
    </Grid>
</local:DSDspScreenBase>

