<UserControl x:Class="DSDsp.画面.HET003_出場選手紹介"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:DSDsp.画面"
             xmlns:parts="clr-namespace:DSDsp.パーツ"
             xmlns:frame="clr-namespace:DSDsp.フレーム"
             mc:Ignorable="d"
             Height="387" Width="641">
    <Grid RenderTransformOrigin="0.161,0.542">
        <!-- フレーム16対9背景 -->
        <frame:フレーム16対9_UC x:Name="FrameBackground"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"/>
        
        <!-- 左上パーツ: JDSFロゴと競技会名 -->
        <parts:COM001_左上 x:Name="PartsCOM001"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"
                   Margin="0,0,0,0"/>
        
        <!-- 右上01パーツ: 種目名 -->
        <parts:COM002_右上01 x:Name="PartsCOM002"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Top"
                     Margin="0,0,0,0"/>
        
        <!-- 右上02パーツ: 現在時刻 -->
        <parts:COM003_右上02 x:Name="PartsCOM003"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Top"
                     Margin="0,0,0,0"/>
        
        <!-- 一覧リスト大パーツ: 出場選手リスト -->
        <parts:LST001_大リスト8 x:Name="PartsLST001"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Top"
                          Margin="0,0,0,0"/>
    </Grid>
</UserControl>

